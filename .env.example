# PostgreSQL — matches docker-compose defaults
DATABASE_URL="postgresql://pulse:pulse_dev_password@localhost:5432/the_pulse?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public site config
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="The Pulse"

# Optional: S3-compatible media storage (falls back to external URLs if unset)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Optional: protects /api/cron/release-scheduled (sent as "Authorization: Bearer <secret>")
CRON_SECRET=""
