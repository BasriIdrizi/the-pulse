# Copy this file to `.env` and fill in real values. Never commit the real .env.

# PostgreSQL — used by BOTH the Postgres container and the app connection.
POSTGRES_PASSWORD="change-me-to-a-strong-password"

# Only used by commands run directly on the host (prisma migrate/seed), which
# reach Postgres via its published port. Must use the SAME password as above.
DATABASE_URL="postgresql://pulse:change-me-to-a-strong-password@localhost:5432/the_pulse?schema=public"

# Auth.js — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="https://readpulsedaily.com"
AUTH_TRUST_HOST="true"

# Public site config (NEXT_PUBLIC_SITE_URL is baked in at build time)
NEXT_PUBLIC_SITE_URL="https://readpulsedaily.com"
NEXT_PUBLIC_SITE_NAME="The Pulse"

# Optional: S3-compatible media storage (falls back to external URLs if unset)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Optional: protects /api/cron/release-scheduled (sent as "Authorization: Bearer <secret>")
CRON_SECRET=""
